{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "outDir": "electron-dist",
    "rootDir": "electron",
    "types": ["node", "electron"],
    "skipLibCheck": true
  },
  "include": ["electron/**/*.ts"]
}
